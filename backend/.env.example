# -----------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://user:password@host:5432/persistent_memory

# -----------------------------------------------------------------------
# Embeddings (optional — defaults shown)
# -----------------------------------------------------------------------
EMBEDDING_DIMENSION=512
DB_ECHO=false

# -----------------------------------------------------------------------
# OpenAI / LLM (api key required; model and retries are optional)
# -----------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_RETRIES=2
